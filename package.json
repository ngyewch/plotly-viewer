{
  "name": "plotly-viewer",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "doDev": "vite",
    "doBuild": "cross-env NODE_ENV=production vite build",
    "doPreview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "watch:check": "svelte-check --tsconfig ./tsconfig.app.json --watch --compiler-warnings a11y-click-events-have-key-events:ignore",
    "dev": "run-p watch:* doDev",
    "build": "run-s check doBuild",
    "preview": "run-s build doPreview"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "7.1.2",
    "@tsconfig/svelte": "5.0.8",
    "@types/node": "24.12.4",
    "@types/plotly.js": "3.0.10",
    "buffer": "6.0.3",
    "gh-pages": "6.3.0",
    "cross-env": "10.1.0",
    "npm-run-all2": "9.0.1",
    "stream-browserify": "3.0.0",
    "svelte-check": "4.5.0",
    "typescript": "6.0.3",
    "vite": "8.0.16"
  },
  "dependencies": {
    "@smui/button": "8.0.3",
    "@smui/icon-button": "8.0.3",
    "plotly.js": "3.6.0",
    "svelte": "5.56.1",
    "svelte-5-french-toast": "2.0.6",
    "svelte-jsoneditor": "3.12.0",
    "svelte-material-ui": "8.0.3",
    "svelte-splitpanes": "8.0.9"
  }
}
